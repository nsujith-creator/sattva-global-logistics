{
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/appointments", "destination": "/", "permanent": true },
    { "source": "/services-store", "destination": "/services", "permanent": true },
    { "source": "/services-store/:path*", "destination": "/services", "permanent": true }
  ],
  "rewrites": [
    { "source": "/googleb46c26284a31cefe.html", "destination": "/googleb46c26284a31cefe.html" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/llms.txt", "destination": "/llms.txt" },
    { "source": "/trade-advisory", "destination": "/trade-advisory/index.html" },
    { "source": "/contact", "destination": "/contact/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
