{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "sattvaglobal.in" }],
      "destination": "https://www.sattvaglobal.in/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/googleb46c26284a31cefe.html", "destination": "/googleb46c26284a31cefe.html" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
